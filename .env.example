# ============================================================================
#  english-tutor — example configuration
#  Copy to `.env` and fill in real values. NEVER commit the real `.env`.
#  Everything defaults to safe offline STUBS, so the full loop runs with an
#  empty .env (no secrets, no network). Fill keys in only as you enable reals.
# ============================================================================

# ---- Telegram bot (learner-facing UX) -------------------------------------
BOT_TOKEN=                       # @BotFather token; required only for live bot
ADMIN_USER_ID=764315256          # your Telegram user id (single-user MVP)

# ---- Telegram userbot (channel scraping, MTProto) -------------------------
TG_API_ID=                       # from https://my.telegram.org
TG_API_HASH=
TG_SESSION_STRING=               # OR leave blank and use TG_SESSION_PATH
TG_SESSION_PATH=bot_data/telegram_e2e_session
SCRAPE_CHANNELS=1137165265,1356345589
MIN_ARTICLE_LEN=350              # skip posts shorter than this (blurbs/ads) when scraping

# ---- Ollama / LLM ---------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=glm-5:cloud         # NOTE: ":cloud" is Ollama cloud-routed; swap to a local tag for fully-offline
OLLAMA_API_KEY=ollama            # dummy value; the openai client requires a non-empty key

# ---- Adapter selection (stub keeps everything offline) --------------------
LLM_BACKEND=stub                 # stub | ollama | hermes
STT_BACKEND=stub                 # stub | whisper | cloud
TTS_BACKEND=stub                 # stub | edge | cloud
ANKI_BACKEND=genanki             # genanki | ankiconnect | null
NOTIFIER_BACKEND=stub            # stub | telegram

# ---- Anki -----------------------------------------------------------------
ANKICONNECT_URL=http://localhost:8765
ANKI_DECK=TOEFL::Daily

# ---- STT (set STT_BACKEND=cloud + a key below for real transcription) ------
GROQ_API_KEY=                    # Groq -> whisper-large-v3 (fast, cheap, recommended)
OPENAI_API_KEY=                  # OpenAI -> whisper-1 (used if no GROQ key)
STT_MODEL=                       # blank -> provider default
STT_MAX_SECONDS=720              # transcribe only the first N seconds (cost/size cap)

# ---- Hermes (optional; conversational plane only, never the graded path) ----
HERMES_ENABLED=false
HERMES_HOME=
HERMES_BASE_URL=                 # OpenAI-compatible endpoint for conversational turns
HERMES_MODEL=                    # defaults to OLLAMA_MODEL if blank
HERMES_API_KEY=
# To use Hermes for free-form chat: set LLM_BACKEND=hermes, HERMES_ENABLED=true,
# and HERMES_BASE_URL. complete_json (quizzes) ALWAYS stays on direct Ollama.

# ---- Schedule / paths -----------------------------------------------------
TZ=Europe/Moscow
REFRESH_CRON=0 7 * * *            # scrape channels + ingest podcasts (before morning push)
MORNING_CRON=30 7 * * *
EVENING_CRON=0 20 * * *
DB_PATH=data/tutor.db
DATA_DIR=data
SOUL_DIR=soul

# ---- Server access (already present; used for deploy, not the app) ---------
SERVER_HOST=
SERVER_USER=
SERVER_PASSWORD=
